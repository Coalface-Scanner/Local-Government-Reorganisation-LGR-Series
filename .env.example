# Supabase Configuration (Required)
# Get these values from your Supabase project dashboard: https://app.supabase.com
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site Password Protection (Optional)
# If set, the entire site will be password-protected via PasswordProtection component
# Leave empty if you don't want site-wide password protection
VITE_SITE_PASSWORD=

# Admin Article Editor Password (Optional)
# Password for accessing the article editor at /admin/articles/login
# Leave empty if you don't want article editor password protection
VITE_ADMIN_PASSWORD=

# Members Password Protection (Optional)
# Password for accessing members-only content (e.g., council profiles, insights/reports, Surrey hub)
# /reorganisations is always public. Falls back to VITE_SITE_PASSWORD if not set.
# Leave empty if you don't want members password protection
VITE_MEMBERS_PASSWORD=
