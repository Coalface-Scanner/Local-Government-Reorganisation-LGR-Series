{
  "name": "lgr-series-website",
  "private": true,
  "version": "1.0.0",
  "description": "Local Government Reorganisation (LGR) Insights Website - Expert analysis and insights on local government reorganisation in England",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "open-local": "open http://localhost:5173",
    "build": "vite build && npx tsx generate-sitemap.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "healthcheck": "npm run lint && npm run typecheck && npm run build",
    "security:scan": "node src/lib/check-hardcoded-secrets.js",
    "security:sanitize-content": "node src/lib/sanitize-cms-content.js",
    "upload-content": "node scripts/upload-content.js",
    "upload-facts": "node scripts/upload-facts.js",
    "import-substack": "node scripts/import-substack-rss.js",
    "import-substack:update": "node scripts/import-substack-rss.js --update",
    "add-moran-article": "node scripts/add-robert-moran-article.js",
    "check:contrast": "node scripts/check-color-contrast.js",
    "test:performance": "node scripts/lighthouse-audit.js",
    "audit:images": "node scripts/audit-images.js",
    "crop-banner-logo": "node scripts/crop-banner-logo.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@types/leaflet": "^1.9.21",
    "@types/marked": "^5.0.2",
    "chart.js": "^4.5.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.344.0",
    "marked": "^17.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-leaflet": "^4.2.1",
    "react-quill": "^2.0.0",
    "react-router-dom": "^6.30.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@prerenderer/renderer-puppeteer": "^1.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "body-parser": "^2.2.2",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^17.0.0",
    "postcss": "^8.4.35",
    "puppeteer": "^24.37.5",
    "sharp": "^0.34.5",
    "terser": "^5.44.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-prerender-k": "^1.0.14"
  }
}
